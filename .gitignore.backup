cat >> .gitignore <<'EOF'

# ------------------------------------------------------------
# Python bytecode and cache
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------------------------
# Python environments
# ------------------------------------------------------------
.env
.env.*
.venv/
venv/
env/

# ------------------------------------------------------------
# Testing and coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
junit.xml

# ------------------------------------------------------------
# Type checking and linting
# ------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pyright/

# ------------------------------------------------------------
# Build and packaging
# ------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# ------------------------------------------------------------
# macOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ------------------------------------------------------------
# IDE and editor files
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# Logs and temporary output
# ------------------------------------------------------------
*.log
tmp/
temp/

# ------------------------------------------------------------
# Binary and executable artifacts
# ------------------------------------------------------------
*.exe
*.dll
*.sys
*.scr
*.com
*.msi
*.bin
*.elf
*.so
*.dylib
*.o
*.obj
*.app

# ------------------------------------------------------------
# Local analysis samples
# Keep only the policy README in version control
# ------------------------------------------------------------
samples/*
!samples/README.md

# ------------------------------------------------------------
# Local datasets
# Keep documentation and references, but avoid accidental
# submission of large or restricted binary datasets
# ------------------------------------------------------------
datasets/benign/*
!datasets/benign/.gitkeep

# ------------------------------------------------------------
# Generated reports and case bundles
# ------------------------------------------------------------
reports/
case_bundles/
analysis_output/
EOF